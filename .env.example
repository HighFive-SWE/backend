# ─────────────────────────────────────────────────────────────────────────────
# HighFive — backend .env.example
#
# fastapi reads its config from environment variables via core/config.py.
# copy this file to `.env` (gitignored) and fill in real values. on macOS /
# linux you can `source .env` before running uvicorn, or use a tool like
# `direnv` / `python-dotenv` for auto-loading.
# ─────────────────────────────────────────────────────────────────────────────


# environment label. accepts: dev | staging | prod. read in
# backend/core/config.py:13. controls log verbosity and feature gates.
HIGHFIVE_ENV=dev

# comma-separated list of origins permitted to call the api (CORS).
# defaults to http://localhost:3000 when unset.
# example for prod:
#   HIGHFIVE_CORS_ORIGINS=https://highfive.app,https://www.highfive.app
HIGHFIVE_CORS_ORIGINS=http://localhost:3000


# === optional / future =======================================================

# postgres connection string — currently unused (state lives in-memory).
# wire this up when persistence lands.
# DATABASE_URL=postgresql+asyncpg://highfive:highfive@localhost:5432/highfive

# redis url for caching + rate limiting (future).
# REDIS_URL=redis://localhost:6379/0

# jwt signing secret. generate with `openssl rand -hex 32`. never reuse
# across environments and never commit a real value.
# JWT_SECRET=

# how long an access token stays valid (seconds). default 3600.
# JWT_TTL_SECONDS=3600

# sentry dsn for server-side error reporting (optional).
# SENTRY_DSN=

# log level — DEBUG / INFO / WARNING / ERROR. defaults to INFO.
# LOG_LEVEL=INFO
